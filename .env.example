# Turso (libSQL) database — created with the Turso CLI (see README / setup).
# The web app reads from this DB; the ingestion pipeline writes to it.
# Locally: copy this file to `.env` and fill in the two values below.
TURSO_DATABASE_URL="libsql://your-db-name-yourorg.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# Anthropic API key — used ONLY by the ingestion pipeline (AI enrichment).
# It must NEVER be exposed to the web app or committed. In production it lives
# only in GitHub Secrets. Leave empty until the AI phase.
ANTHROPIC_API_KEY=""
